{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": ["bun-types"]
  },
  "include": [
    "scripts/**/*.ts",
    "src/app.test.tsx",
    "src/app.tsx",
    "src/index.ts",
    "src/gamebook/**/*.ts"
  ]
}
